# ============================================================
#  companion relay — environment template
#  Copy to  relay.env  and fill in. NEVER commit the filled file.
#    cp .env.example relay.env && chmod 600 relay.env
# ============================================================

# ---- REQUIRED: shared auth secret --------------------------------
# ONE secret guards every endpoint. The PWA and the local channel plugin
# both send it as a Bearer token. Generate a fresh random one (do NOT reuse
# anyone else's):
#     python3 -c "import secrets; print(secrets.token_urlsafe(32))"
RELAY_SECRET=

# ---- identity (your names) ---------------------------------------
RELAY_AI_NAME=Claude          # <- your AI companion's display name (push title, narration)
RELAY_HUMAN_NAME=你的名字       # <- how the AI is told about you in voice/call narration ("…开启了语音通话")

# ---- paths / network ---------------------------------------------
RELAY_PORT=3011
RELAY_DB=/root/companion-relay/relay.db
RELAY_UPLOAD_DIR=/root/companion-relay/uploads
# Public URL prefix nginx mounts the API under (MUST match your nginx `location`).
# Upload URLs are built as  <prefix>/uploads/<file>  — so this must be correct.
RELAY_PUBLIC_PREFIX=/relay
# Where a push-notification tap should open the PWA (your nginx static prefix).
RELAY_APP_PATH=/chat/
# CORS allow-list (comma separated). Put your real https origin first.
RELAY_ALLOW_ORIGINS=https://your-domain.example,http://localhost:8080

# ---- optional API loop routing -----------------------------------
# Default "desktop" means PWA messages go to the Claude Code channel plugin.
# POST /app/brain {"target":"loop"} writes RELAY_BRAIN_FILE and sends new
# messages to RELAY_LOOP_INGEST_URL instead.
RELAY_BRAIN_FILE=/root/companion-relay/brain_target
RELAY_LOOP_INGEST_URL=http://127.0.0.1:3020/loop/ingest

# ---- upload limits -----------------------------------------------
RELAY_MAX_UPLOAD_BYTES=10485760   # 10 MB (keep <= nginx client_max_body_size)
RELAY_VOICE_MAX_BYTES=8388608     # 8 MB
# Optional local ASR hook: a command taking  <audio_path> <mime>  that prints a transcript.
# Leave blank to just deliver voice as an audio attachment.
RELAY_VOICE_TRANSCRIBE_CMD=

# ---- Aliyun Bailian realtime ASR (OPTIONAL — call mode live transcription) ----
BAILIAN_API_KEY=
BAILIAN_WORKSPACE_ID=
BAILIAN_REALTIME_ASR_WS_ENDPOINT=
BAILIAN_REALTIME_ASR_MODEL=fun-asr-realtime
BAILIAN_REALTIME_ASR_SAMPLE_RATE=16000
BAILIAN_REALTIME_ASR_LANGUAGE=zh
BAILIAN_REALTIME_ASR_MAX_SILENCE=800

# ---- MiniMax TTS (OPTIONAL — leave keys blank to disable spoken replies) ----
# Get your own keys at the MiniMax console and create a voice id.
MINIMAX_API_BASE=https://api.minimaxi.com
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=speech-02-hd
MINIMAX_VOICE_ZH=
MINIMAX_TTS_TIMEOUT=30

# ---- Web Push / VAPID (OPTIONAL — leave blank to disable lock-screen push) ----
# Generate your OWN key pair (see DEPLOY.md, "Web Push"). Never reuse another's.
#   VAPID_PUBLIC_KEY  = the base64url applicationServerKey the browser subscribes with
#   VAPID_PRIVATE_PEM = path to private_key.pem (or the inline PEM text)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_PEM=/root/companion-relay/private_key.pem
VAPID_SUBJECT=mailto:you@your-domain.example

# ---- presence tuning (seconds) -----------------------------------
RELAY_PRESENCE_ONLINE_SEC=180
RELAY_PRESENCE_RECENT_SEC=1800
